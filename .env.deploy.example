T3MT_API_KEY=
OPENAI_API_KEY=

# T3FAP API 地址。
# 和 T3FAP 在同一个 Docker 网络时用 http://t3fap:8521
# 通过宿主机端口访问时用 http://host.docker.internal:8521
T3MT_HOST=http://t3fap:8521

# 仅 compose.ai-only.yaml 需要。
# 填 T3FAP 容器所在 Docker 网络名。
T3FAP_DOCKER_NETWORK=t3fap_default

T3FAP_ASSISTANT_MODEL_NAME=gpt-5.4
T3FAP_ASSISTANT_MODEL=openai/gpt-5.4
T3FAP_ASSISTANT_API_BASE=https://api.openai.com/v1
T3FAP_ASSISTANT_PICO_TOKEN=
